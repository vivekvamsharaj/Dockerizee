# Copy this file to .env and adjust values as needed
# cp .env.example .env

# Port the app listens on and is exposed on
PORT=5000

# Node environment
NODE_ENV=production

# Name of the MongoDB database (used inside docker-compose)
MONGO_DB_NAME=tododb

# Full Mongo connection string (only needed if running the app WITHOUT
# docker-compose, e.g. connecting to a local or Atlas MongoDB instance)
MONGO_URI=mongodb://localhost:27017/tododb
